{
  "name": "qa-assessment-survey",
  "version": "0.0.0",
  "private": true,
  "description": "qa-assessment-survey",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "dotenv -e apps/api/.env.test -- vitest run",
    "lint": "echo \"(placeholder de lint)\""
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@swc/core": "^1.11.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.0.7",
    "jsdom": "^24.0.0",
    "unplugin-swc": "^1.5.1",
    "vite": "^5.4.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
